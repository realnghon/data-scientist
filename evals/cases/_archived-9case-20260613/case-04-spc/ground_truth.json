{
  "case_id": "case-04-spc",
  "datasets": [
    "dataset.csv"
  ],
  "format": "multi-line time series (2160 rows, 3 lines × 30 days × 24h)",
  "target": "measurement_mm",
  "routing": {
    "expected_route": "full",
    "must_produce_artifacts": [
      "data_manifest",
      "readiness_report",
      "analysis_plan",
      "evidence_matrix",
      "final_report"
    ],
    "must_not_produce": []
  },
  "artifacts": {
    "analysis_plan": {
      "required_keys": [
        "claims"
      ]
    },
    "readiness_report": {
      "min_dimensions": 8,
      "allowed_scores": [
        "ok",
        "partial",
        "blocked"
      ]
    }
  },
  "findings": [
    {
      "id": "stratify_by_line",
      "type": "method",
      "feature": "stratification",
      "evidence_regex": "(stratif|分层|by.*line|按.*产线|per.*line|each.*line|L1.*L2.*L3)"
    },
    {
      "id": "l3_out_of_control",
      "type": "claim",
      "feature": "L3_instability",
      "evidence_regex": "(L3|line.*3|产线.*3)[^\\n]{0,300}(out.?of.?control|失控|不稳定|unstable|special.*cause|特殊.*原因)"
    },
    {
      "id": "l3_timeframe",
      "type": "claim",
      "feature": "L3_period",
      "evidence_regex": "(L3|line.*3|产线.*3)[^\\n]{0,400}(5月|May|day|时段|period|连续|持续|全天)"
    },
    {
      "id": "l1_stable",
      "type": "claim",
      "feature": "L1_stability",
      "evidence_regex": "(L1|line.*1|产线.*1)[^\\n]{0,300}(stable|稳定|in.*control|受控|excellent|优秀)"
    },
    {
      "id": "capability_reported",
      "type": "quality",
      "feature": "Cp_Cpk",
      "evidence_regex": "(Cp|Cpk|过程能力)[^\\n]{0,500}(1\\.[0-9]|2\\.[0-9])"
    }
  ],
  "charts": {
    "min_count": 2
  },
  "anti_patterns": []
}