{
  "case_id": "case-01-manufacturing-full-v2",
  "datasets": ["dataset_v2.csv"],
  "format": "single table (500 rows × 9 columns)",
  "target": "yield_pct",
  "routing": {
    "expected_route": "full",
    "must_produce_artifacts": ["data_manifest", "readiness_report", "analysis_plan", "evidence_matrix", "final_report"],
    "must_not_produce": []
  },
  "artifacts": {
    "analysis_plan": {"required_keys": ["claims", "data_transformations"]},
    "readiness_report": {"min_dimensions": 8, "allowed_scores": ["ok", "partial", "blocked"]}
  },
  "findings": [
    {
      "id": "temperature_main_effect",
      "type": "claim",
      "feature": "temperature",
      "evidence_regex": "(temperature|温度)[^\\n]{0,200}(180.*200|optimal|最优|out.*range|超出.*范围)"
    },
    {
      "id": "interaction_detected",
      "type": "claim",
      "feature": "interaction",
      "evidence_regex": "((equipment.?age|设备.*年龄|年龄|age)[^\\n]{0,300}(temperature|温度|temp)[^\\n]{0,300}(interact|交互|amplif|放大|moderat|调节))|((temperature|温度|temp)[^\\n]{0,300}(equipment.?age|设备.*年龄|年龄|age)[^\\n]{0,300}(interact|交互|amplif|放大|moderat|调节))"
    },
    {
      "id": "noise_rejected",
      "type": "negative_claim",
      "feature": "noise",
      "evidence_regex": "(pressure|humidity|line.?speed|operator|shift|压力|湿度|线速|操作员|班次)[^\\n]{0,200}(no (significant|显著)|无.*效应|noise|噪声|weak|弱|not.*driver|非.*驱动)"
    },
    {
      "id": "interaction_check_executed",
      "type": "quality",
      "feature": "method",
      "evidence_regex": "(interaction.*term|交互.*项|model.*interaction|age.*×.*temp|temp.*×.*age|age.*\\*.*temp)"
    }
  ],
  "charts": {"min_count": 2},
  "anti_patterns": []
}
