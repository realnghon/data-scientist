{
  "case_id": "case-04-spc",
  "dataset": "dataset.csv",
  "target": "measurement_mm",
  "routing": {
    "expected_route": "full",
    "must_produce_artifacts": ["data_manifest", "readiness_report", "analysis_plan", "evidence_matrix", "final_report"],
    "must_not_produce": []
  },
  "artifacts": {
    "analysis_plan": {"required_keys": ["claims", "rejected_alternatives"]},
    "readiness_report": {"min_dimensions": 8, "allowed_scores": ["ok", "partial", "blocked"]}
  },
  "findings": [
    {
      "id": "process_unstable",
      "type": "claim",
      "feature": "stability",
      "evidence_regex": "(not (statistically )?in[- ]control|不(处于|是)?(统计)?受控|unstable|不稳定|out[- ]of[- ]control|失控)"
    },
    {
      "id": "shift_detected_rule2",
      "type": "anomaly",
      "feature": "shift",
      "evidence_regex": "(50[01]|5[01][0-9]|520)[^\\n]{0,200}(shift|偏移|连续.{0,12}(上方|above)|run above|Rule ?2|均值上移)|(shift|偏移|连续点在中心线上方)[^\\n]{0,200}(50[01]|5[01][0-9]|520)"
    },
    {
      "id": "trend_detected_rule6",
      "type": "anomaly",
      "feature": "trend",
      "evidence_regex": "(60[0-9]|6[1-4][0-9]|650)[^\\n]{0,200}(trend|趋势|上升|increasing|drift)|(trend|趋势|连续上升)[^\\n]{0,200}(60[0-9]|6[1-4][0-9]|650)"
    },
    {
      "id": "cp_inadequate",
      "type": "numeric_claim",
      "feature": "cp",
      "evidence_regex": "Cpk?[^\\n]{0,160}(0\\.[7-9])",
      "numeric": {"description": "Cp on in-control baseline segment", "pattern": "Cp[^0-9]{0,20}(0\\.[7-9][0-9]?)", "expected": 0.81, "tolerance": 0.12}
    },
    {
      "id": "capability_on_stable_segment_only",
      "type": "quality",
      "feature": "methodology",
      "evidence_regex": "(in[- ]control (segment|portion|baseline)|受控(段|区间|基线)|剔除.{0,20}(失控|特殊原因)|exclud\\w+.{0,40}(out[- ]of[- ]control|special cause)|前\\s*500)"
    }
  ],
  "charts": {"min_count": 2, "required_keywords": ["control|控制|imr|i_mr|xbar", "capab|能力|histogram|直方"]},
  "anti_patterns": [
    {
      "id": "no_capability_on_unstable_process",
      "forbidden_regex": "(过程稳定且能力充足|process is stable and capable)",
      "scope": "final_report"
    }
  ]
}
