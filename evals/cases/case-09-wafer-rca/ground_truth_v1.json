{
  "case_id": "case-09-wafer-rca",
  "dataset": "dataset.csv",
  "format": "long (pivot required)",
  "target": "yield_pct",
  "routing": {
    "expected_route": "full",
    "must_produce_artifacts": ["data_manifest", "readiness_report", "analysis_plan", "evidence_matrix", "final_report"],
    "must_not_produce": []
  },
  "artifacts": {
    "analysis_plan": {"required_keys": ["claims", "data_transformations"]},
    "readiness_report": {"min_dimensions": 8, "allowed_scores": ["ok", "partial", "blocked"]}
  },
  "findings": [
    {
      "id": "pivot_executed",
      "type": "transformation",
      "feature": "data_reshape",
      "evidence_regex": "(pivot|wide|reshape|行转列|长(格式)?(转|变|改).{0,20}宽)|wafer.*station.*param"
    },
    {
      "id": "cd_nm_root_cause",
      "type": "claim",
      "feature": "cd_nm",
      "evidence_regex": "(cd[_\\s]?nm|critical[\\s_]?dimension)[^\\n]{0,300}(driver|root[\\s_-]?cause|根(本)?原因|主(要)?驱动|最强|dominant|primary)"
    },
    {
      "id": "litho_station_identified",
      "type": "claim",
      "feature": "litho",
      "evidence_regex": "litho[^\\n]{0,200}(yield|良率|cd[_\\s]?nm)"
    },
    {
      "id": "spec_violation_detected",
      "type": "anomaly",
      "feature": "out_of_spec",
      "evidence_regex": "(out[\\s_-]?of[\\s_-]?spec|超(出)?规格|偏离|deviation|85.*95|规格(范围|限))"
    },
    {
      "id": "noise_params_rejected",
      "type": "negative_claim",
      "feature": "etch_rate",
      "evidence_regex": "(etch[_\\s]?rate|dep[_\\s]?thickness|implant[_\\s]?dose)[^\\n]{0,200}(not (significant|驱动)|无(显著)?效应|noise|噪声|weak|弱)"
    }
  ],
  "charts": {"min_count": 2},
  "anti_patterns": [
    {
      "id": "no_pivot_skipped",
      "forbidden_regex": "^(?!.*(pivot|wide|reshape)).*yield.*analysis",
      "scope": "final_report"
    }
  ]
}
