{
  "case_id": "case-09-wafer-rca-v2",
  "datasets": ["fab_log.csv", "metrology.csv"],
  "format": "multi-source (join + pivot required)",
  "target": "yield_pct",
  "routing": {
    "expected_route": "full",
    "must_produce_artifacts": ["data_manifest", "readiness_report", "analysis_plan", "evidence_matrix", "final_report"],
    "must_not_produce": []
  },
  "artifacts": {
    "analysis_plan": {"required_keys": ["claims", "data_transformations"]},
    "readiness_report": {"min_dimensions": 8, "allowed_scores": ["ok", "partial", "blocked"]}
  },
  "findings": [
    {
      "id": "join_executed",
      "type": "transformation",
      "feature": "data_join",
      "evidence_regex": "(join|merge|合并|连接)[^\\n]{0,200}(wafer[_\\s]?id|fab[_\\s]?log.*metrology)"
    },
    {
      "id": "pivot_executed",
      "type": "transformation",
      "feature": "data_reshape",
      "evidence_regex": "(pivot|wide|reshape|行转列|长(格式)?(转|变|改).{0,20}宽)"
    },
    {
      "id": "chamber_c2_root_cause",
      "type": "claim",
      "feature": "chamber",
      "evidence_regex": "((C2|chamber|机台)[^\\n]{0,200}(root.?cause|根.?因|主.?驱动|driver|关键.?因))|((root.?cause|根.?因|主.?驱动|driver|关键.?因)[^\\n]{0,200}(C2|chamber|机台))"
    },
    {
      "id": "cd_nm_mechanism",
      "type": "claim",
      "feature": "cd_nm",
      "evidence_regex": "(cd[_\\s]?nm|critical[\\s_]?dimension)[^\\n]{0,300}(out[\\s_-]?of[\\s_-]?spec|超(出)?规格|偏离|85.*95)"
    },
    {
      "id": "litho_station_identified",
      "type": "claim",
      "feature": "litho",
      "evidence_regex": "litho[^\\n]{0,200}(chamber|C2|cd[_\\s]?nm)"
    },
    {
      "id": "recipe_waiting_noise_rejected",
      "type": "negative_claim",
      "feature": "recipe",
      "evidence_regex": "(recipe|waiting[_\\s]?time|process[_\\s]?time).{0,400}(not|无|weak|弱|noise|噪声|test|测试|check|检查|ANOVA|卡方|Chi)"
    },
    {
      "id": "same_event_features_flagged",
      "type": "quality",
      "feature": "leakage",
      "evidence_regex": "(final[_\\s]?test|same[\\s_-]?event|同(一)?站点|同时(刻)?测量|leakage|泄漏|post.*event|target.*derived)"
    }
  ],
  "charts": {"min_count": 2},
  "anti_patterns": [
    {
      "id": "no_join_skipped",
      "forbidden_regex": "yield.*analysis.*(?!.*(join|merge))",
      "scope": "analysis_plan"
    }
  ]
}
