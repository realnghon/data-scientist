{
  "case_id": "case-09-wafer-rca-v3",
  "datasets": ["fab_log.csv", "metrology.csv"],
  "format": "multi-source (join + pivot required)",
  "target": "yield_pct",
  "routing": {
    "expected_route": "full",
    "must_produce_artifacts": ["data_manifest", "readiness_report", "analysis_plan", "evidence_matrix", "final_report"],
    "must_not_produce": []
  },
  "artifacts": {
    "analysis_plan": {"required_keys": ["claims"]},
    "readiness_report": {"min_dimensions": 8, "allowed_scores": ["ok", "partial", "blocked"]}
  },
  "findings": [
    {
      "id": "chamber_c2_root_cause",
      "type": "claim",
      "feature": "chamber",
      "evidence_regex": "((C2|chamber)[^\\n]{0,400}(root.?cause|根.?因|driver|驱动|yield.?(low|drop|差|低|70)))|((root.?cause|根.?因|driver)[^\\n]{0,300}C2)",
      "note": "Core finding: Chamber C2 identified as root cause"
    },
    {
      "id": "cd_nm_mechanism",
      "type": "claim",
      "feature": "cd_nm",
      "evidence_regex": "(cd[_\\s]?nm|critical[\\s_]?dimension)[^\\n]{0,500}(correlation|相关|mechanism|机制|driver|驱动|7[6-9]|differ|below|低于|out.?spec|超.?规格)",
      "note": "Mechanism: cd_nm explains why C2 fails"
    }
  ],
  "charts": {"min_count": 1},
  "anti_patterns": [],
  "notes": "Simplified GT v3: Focus on core findings only (chamber + mechanism). Removed overly specific requirements (recipe rejection, leakage flagging, litho station, data transformation details). These can be quality bonuses but not hard requirements."
}
