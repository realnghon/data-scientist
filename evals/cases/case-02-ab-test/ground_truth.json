{
  "case_id": "case-02-ab-test",
  "dataset": "../../../examples/ab_test/dataset.csv",
  "target": "converted",
  "routing": {
    "expected_route": "full",
    "must_produce_artifacts": ["data_manifest", "readiness_report", "analysis_plan", "evidence_matrix", "final_report"],
    "must_not_produce": []
  },
  "artifacts": {
    "analysis_plan": {"required_keys": ["claims", "rejected_alternatives"]},
    "readiness_report": {"min_dimensions": 8, "allowed_scores": ["ok", "partial", "blocked"]}
  },
  "findings": [
    {
      "id": "conversion_lift_significant",
      "type": "numeric_claim",
      "feature": "converted",
      "evidence_regex": "(conversion|转化)[^\\n]{0,300}(significant|显著)",
      "numeric": {"description": "treatment vs control conversion lift in percentage points", "pattern": "(1\\.[5-9]|2\\.[0-9]|3\\.[0-3])\\s*(pp|个百分点|percentage point|%)", "expected": 2.0, "tolerance": 1.0}
    },
    {
      "id": "effect_size_with_ci",
      "type": "quality",
      "feature": "ci",
      "evidence_regex": "(95% ?(CI|置信区间)|confidence interval|\\[[0-9.]+%?,\\s*[0-9.]+%?\\])"
    },
    {
      "id": "srm_check_performed",
      "type": "quality",
      "feature": "srm",
      "evidence_regex": "(SRM|sample ratio|样本比例|分流(比例|均衡)|5000)"
    },
    {
      "id": "revenue_lift_detected",
      "type": "driver",
      "feature": "revenue",
      "direction": "positive",
      "evidence_regex": "(revenue|收入)[^\\n]{0,300}(higher|提升|增加|increase|lift|更高)"
    }
  ],
  "charts": {"min_count": 2, "required_keywords": []},
  "anti_patterns": [
    {
      "id": "no_pvalue_only_claims",
      "forbidden_regex": "仅凭p值|only the p-value matters",
      "scope": "final_report"
    }
  ]
}
