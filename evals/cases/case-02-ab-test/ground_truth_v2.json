{
  "case_id": "case-02-ab-v2",
  "datasets": ["dataset_v2.csv"],
  "format": "A/B test (20000 users, 4 metrics with tradeoff)",
  "target": "multiple metrics (conversion, revenue, session_duration, bounce)",
  "routing": {
    "expected_route": "full",
    "must_produce_artifacts": ["data_manifest", "readiness_report", "analysis_plan", "evidence_matrix", "final_report"],
    "must_not_produce": []
  },
  "artifacts": {
    "analysis_plan": {"required_keys": ["claims"]},
    "readiness_report": {"min_dimensions": 8, "allowed_scores": ["ok", "partial", "blocked"]}
  },
  "findings": [
    {
      "id": "conversion_positive",
      "type": "claim",
      "feature": "conversion_lift",
      "evidence_regex": "(conversion|转化)[^\\n]{0,400}(treatment|实验组|T组)[^\\n]{0,400}(increase|improve|提升|positive|higher|更高|\\+[0-9]+|[0-9]+\\.[0-9]+%|33)"
    },
    {
      "id": "engagement_negative",
      "type": "claim",
      "feature": "engagement_drop",
      "evidence_regex": "(session.*duration|会话.*时长|engagement|参与|时长)[^\\n]{0,400}(treatment|实验组|T组)[^\\n]{0,400}(decreas|declin|下降|负|shorter|减少|worse|lower|更低|-[0-9]+|15)"
    },
    {
      "id": "tradeoff_acknowledged",
      "type": "quality",
      "feature": "tradeoff_discussion",
      "evidence_regex": "(tradeoff|权衡|trade.*off|利弊|gain.*loss|提升.*下降|positive.*negative|wins.*losses|conversion.*session|转化.*时长|核心.*次要)"
    },
    {
      "id": "conditional_recommendation",
      "type": "quality",
      "feature": "decision_logic",
      "evidence_regex": "(recommend.*if|建议.*如果|conditional|取决于|depends.*on|consider.*whether|权衡.*后|综合.*考虑|虽然.*但|although.*but|tradeoff.*建议|考虑.*指标)"
    },
    {
      "id": "effect_size_with_ci",
      "type": "quality",
      "feature": "rigor",
      "evidence_regex": "(\\+[0-9]+\\.[0-9].*pp|effect.*size|效应.*量)[^\\n]{0,200}(CI|confidence|置信|\\[[0-9])"
    }
  ],
  "charts": {"min_count": 2},
  "anti_patterns": [
    {
      "id": "ignore_negative_metric",
      "forbidden_regex": "(recommend|建议).{0,50}(launch|上线|部署|deploy)(?!.{0,200}(session|engagement|bounce|时长|参与|跳出|负面|下降|tradeoff|权衡))",
      "scope": "final_report"
    }
  ]
}
