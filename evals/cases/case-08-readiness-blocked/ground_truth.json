{
  "case_id": "case-08-readiness-blocked",
  "dataset": "dataset.csv",
  "target": "revenue",
  "routing": {
    "expected_route": "blocked",
    "must_produce_artifacts": ["data_manifest", "readiness_report"],
    "must_not_produce": ["evidence_matrix"]
  },
  "artifacts": {
    "readiness_report": {"min_dimensions": 8, "allowed_scores": ["ok", "partial", "blocked"]}
  },
  "findings": [
    {
      "id": "missingness_blocked_detected",
      "type": "claim",
      "feature": "missingness",
      "evidence_regex": "(4[0-9](\\.[0-9])?\\s*%|45%)[^\\n]{0,160}(missing|缺失)|(missing|缺失)[^\\n]{0,120}(4[0-9](\\.[0-9])?\\s*%)"
    },
    {
      "id": "blocked_decision",
      "type": "claim",
      "feature": "readiness_decision",
      "evidence_regex": "(blocked|阻断|无法支持|cannot (reliably )?(answer|support)|不足以(得出|支持))"
    },
    {
      "id": "data_request_emitted",
      "type": "quality",
      "feature": "data_request",
      "evidence_regex": "(data[_ ]request|需要(补充|提供)|missing data needed|请提供|修复.{0,20}(数据|缺失)|backfill)"
    },
    {
      "id": "date_format_issue_flagged",
      "type": "quality",
      "feature": "measurement_reliability",
      "evidence_regex": "(order_date|date|日期)[^\\n]{0,160}(format|格式)[^\\n]{0,120}(inconsistent|混合|mixed|不一致)|(order_date|日期)[^\\n]{0,80}(混用|mixed|inconsistent)[^\\n]{0,80}(format|格式)"
    }
  ],
  "charts": {"min_count": 0, "required_keywords": []},
  "anti_patterns": [
    {
      "id": "no_forced_trend_conclusion",
      "forbidden_regex": "(销售额(正在|确实)(稳定|显著)?增长|revenue is (clearly |significantly )?growing)[^\\n]{0,40}(每|at a rate|by [0-9])",
      "scope": "final_report"
    }
  ]
}
